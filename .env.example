# Supabase Configuration
# Replace these with your actual Supabase project credentials
# You can find these in the Supabase Dashboard:
# Project Settings -> API -> Project API keys (anon public) and Project URL

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Instructions:
# 1. Go to https://supabase.com and log in.
# 2. Select your project.
# 3. Click on the 'Settings' (gear icon) in the sidebar.
# 4. Click on 'API'.
# 5. Copy the 'Project URL' and paste it into VITE_SUPABASE_URL.
# 6. Copy the 'anon' 'public' key and paste it into VITE_SUPABASE_ANON_KEY.
